# ── APP ────────────────────────────────────────────────────────────────────────
APP_NAME=WAYGO
APP_VERSION=1.0.0
APP_ENV=development          # development | staging | production
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── DATABASE ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=waygo
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_POOL_SIZE=100

# ── REDIS ──────────────────────────────────────────────────────────────────────
REDIS_URI=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_USE_256_BIT_RANDOM_KEY_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── EMAIL ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@waygo.app
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@waygo.app
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=2

# ── STORAGE ────────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local          # local | s3 | cloudflare_r2
STORAGE_BUCKET=waygo-media
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_CDN_URL=http://localhost:8000/media
LOCAL_MEDIA_PATH=./media

# ── RATE LIMITING ──────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── GEO ────────────────────────────────────────────────────────────────────────
DEFAULT_VALIDATION_RADIUS_METERS=30.0
MAX_NEARBY_RADIUS_KM=50.0

# ── POINTS ─────────────────────────────────────────────────────────────────────
POINTS_VISIT_PLACE=10
POINTS_UPLOAD_PHOTO=5
POINTS_RECEIVE_LIKE=1
POINTS_COMPLETE_COLLECTION=50
POINTS_EARN_BADGE=100

# ── FLIGHTS (Duffel API — https://duffel.com) ─────────────────────────────────────
DUFFEL_API_KEY=YOUR_DUFFEL_ACCESS_TOKEN_HERE
DUFFEL_API_BASE_URL=https://api.duffel.com
DUFFEL_VERSION=v2

# ── LODGING (Hotelbeds API — https://developer.hotelbeds.com) ─────────────────────
HOTELBEDS_API_KEY=YOUR_HOTELBEDS_API_KEY_HERE
HOTELBEDS_SECRET=YOUR_HOTELBEDS_SECRET_HERE
HOTELBEDS_API_BASE_URL=https://api.test.hotelbeds.com

# ── MONITORING ─────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-key@o0.ingest.us.sentry.io/0
